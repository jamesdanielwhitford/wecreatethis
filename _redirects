# Cloudflare Pages / Netlify redirects

# Domain-wide redirect from old domain to new domain
https://wecreatethis.pages.dev/* https://wecreatethis.com/:splat 301

# Client-side routing support for sub-apps

# Invisible Ink - serve index.html for all invisibleink routes
/invisibleink/*  /invisibleink/index.html  200

# Tarot app routing (if needed in future)
/tarot/*  /tarot/index.html  200

# Birdle app routing (if needed in future)
/birdle/*  /birdle/index.html  200

# Blog: clean URLs for sections (posts use a #fragment, no server routing needed).
# Real files must pass through first (first match wins), then any other
# /blog/... path serves the section shell. Nested sections work with no
# extra rules: adding a content folder needs NO changes here.
/blog/  /blog/  200
/blog/content/*  /blog/content/:splat  200
/blog/app.js  /blog/app.js  200
/blog/style.css  /blog/style.css  200
/blog/sw.js  /blog/sw.js  200
/blog/manifest.json  /blog/manifest.json  200
/blog/content-manifest.json  /blog/content-manifest.json  200
/blog/icon-192.png  /blog/icon-192.png  200
/blog/icon-512.png  /blog/icon-512.png  200
/blog/*  /blog/section  200
